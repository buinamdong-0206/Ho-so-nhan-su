{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "https://api.daihoidangtoanquoc.vn/:path*"
    },
    {
      "source": "/api/proxy-cdn/:path*",
      "destination": "https://cdn.daihoidangtoanquoc.vn/:path*"
    },
    {
      "source": "/share/:listId",
      "destination": "/api/share?listId=:listId"
    },
    {
      "source": "/((?!api|share).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.ts": {
      "includeFiles": "{firebase-applet-config.json,profiles_data.json}"
    }
  }
}
